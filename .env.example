# .env.example
# Copy this file to .env and fill in your values

# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Admin Shortcut Configuration
# These variables are for the Admin shortcut feature (e.g., quick admin access or panel)
ADMIN_SHORTCUT_URL=https://your-admin-shortcut.example.com
ADMIN_SHORTCUT_TOKEN=your_admin_shortcut_token_here
ADMIN_SHORTCUT_SECRET=your_admin_shortcut_secret_here
